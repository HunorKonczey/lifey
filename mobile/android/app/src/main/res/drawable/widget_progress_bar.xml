<?xml version="1.0" encoding="utf-8"?>
<!-- Determinate calorie-progress bar drawable (track + clipped fill), since
     RemoteViews can't set a ColorStateList/tint on a stock ProgressBar
     without API 31. Static per-theme colors via values(-night)/widget_colors. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <solid android:color="@color/widget_progress_track"/>
            <corners android:radius="4dp"/>
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle">
                <solid android:color="@color/widget_calories"/>
                <corners android:radius="4dp"/>
            </shape>
        </clip>
    </item>
</layer-list>
