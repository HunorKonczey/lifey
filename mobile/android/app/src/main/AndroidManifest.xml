<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Required for the app to reach the backend over the network. -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Required to scan food barcodes with the device camera. -->
    <uses-permission android:name="android.permission.CAMERA"/>
    <!-- Android 13+ runtime permission for the step-goal and ongoing
         workout-session notifications (requested lazily, see
         NotificationService / WorkoutSessionNotifierService). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <!-- Health Connect (docs/26-android-health-connect-integration-plan.md)
         — read-only, one permission per HealthDataType HealthService uses.
         ACTIVITY_RECOGNITION is Health Connect's own prerequisite for
         reading step data. -->
    <uses-permission android:name="android.permission.health.READ_STEPS"/>
    <uses-permission android:name="android.permission.health.READ_WEIGHT"/>
    <uses-permission android:name="android.permission.health.READ_HEART_RATE"/>
    <uses-permission android:name="android.permission.health.READ_EXERCISE"/>
    <uses-permission android:name="android.permission.health.READ_ACTIVE_CALORIES_BURNED"/>
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION"/>
    <!-- Morning weigh-in reminder (docs/30-push-notifications-plan.md, M4) —
         lets flutter_local_notifications reschedule its repeating alarm after
         a reboot; without it, the daily reminder silently stops firing until
         the app is next opened. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <!-- Rest timer (docs/39-rest-timer-plan.md) — lets the rest-end
         notification fire at the exact target second instead of drifting by
         minutes; requested lazily (NotificationService.
         requestRestTimerExactAlarmPermission) when the user enables the rest
         timer, with an inexact-alarm fallback if denied. -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"/>
    <application
        android:label="lifey"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- Health Connect routes the user here to show its permissions
                 rationale screen. -->
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE"/>
            </intent-filter>
        </activity>
        <!-- Health Connect's "view permission usage" entry point — links back
             to this app from Health Connect's own settings UI. Required to
             pass Play review when requesting sensitive health permissions. -->
        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE"/>
                <category android:name="android.intent.category.HEALTH_PERMISSIONS"/>
            </intent-filter>
        </activity-alias>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
        <!-- Today's calories home screen widget (docs/25-android-widget-ongoing-notification-plan.md). -->
        <receiver
            android:name=".TodaySummaryWidgetProvider"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE"/>
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/today_summary_widget_info"/>
        </receiver>
        <!-- Required by flutter_local_notifications' zonedSchedule (morning
             weigh-in reminder, docs/30-push-notifications-plan.md, M4) — the
             first fires the notification itself, the second reschedules the
             repeating alarm after a reboot or app update. -->
        <!-- Wakes even if the Flutter engine isn't running, so a workout
             summary sent by the watch right as the app was killed still gets
             buffered (docs/40-watch-app-plan.md §5.4). WatchBridge.kt is the
             live counterpart used while the engine is up. -->
        <service
            android:name=".PhoneWatchSummaryListenerService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data
                    android:scheme="wear"
                    android:host="*"
                    android:path="/lifey/watch/summary" />
            </intent-filter>
        </service>
        <receiver android:exported="false"
            android:name="com.dexterous.flutterlocalnotifications.ScheduledNotificationReceiver"/>
        <receiver android:exported="false"
            android:name="com.dexterous.flutterlocalnotifications.ScheduledNotificationBootReceiver">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED"/>
                <action android:name="android.intent.action.QUICKBOOT_POWERON"/>
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON"/>
            </intent-filter>
        </receiver>
        <!-- Workout music controls (docs/music/46-workout-music-controls-plan.md
             §2.1, M2): exists only so its ComponentName can be passed to
             MediaSessionManager.getActiveSessions/addOnActiveSessionsChangedListener
             — never reads notification content, only the enabled/bound state
             the system grants when the user allows notification access for
             this app (surfaced to the user with prominent disclosure in the
             in-app permission prompt before they're sent here). -->
        <service
            android:name=".MusicNotificationListenerService"
            android:label="lifey"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
            android:exported="false">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService"/>
            </intent-filter>
        </service>
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- Health Connect: lets the app check whether it's installed and
             launch its permissions-rationale screen. -->
        <package android:name="com.google.android.apps.healthdata"/>
        <intent>
            <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE"/>
        </intent>
        <!-- Android 11+ package visibility (docs/40-watch-app-plan.md §5.1):
             without this, MessageClient/DataClient/CapabilityClient calls to
             the watch are silently blocked by the AppsFilter — confirmed via
             "AppsFilter: interaction ... -> com.google.android.apps.wear.companion BLOCKED"
             in logcat. Both package names covered since it varies by Wear OS
             companion version/device. -->
        <package android:name="com.google.android.apps.wear.companion"/>
        <package android:name="com.google.android.wearable.app"/>
        <!-- Workout music controls (docs/music/46-workout-music-controls-plan.md
             §2.1, M2): lets MediaSessionBridge check whether each provider is
             installed (picker sheet) and launch it directly (empty-state CTA). -->
        <package android:name="com.spotify.music"/>
        <package android:name="com.google.android.apps.youtube.music"/>
        <package android:name="com.apple.android.music"/>
    </queries>
</manifest>
