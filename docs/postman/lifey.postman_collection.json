    {
      "name": "Workouts",
      "description": "Implemented feature. Workout templates (named lists of exercises) and logged workout sessions. Both reference exercises by id (manage them via the Exercises folder; ids 1-8 are pre-seeded).\n\nA session has two independent lists: `exerciseIds` (planned exercises — e.g. copied client-side from a template's `exerciseIds` when starting from one) and `sets` (sets actually logged, with reps/weight). Both can be empty: a session can be started blank with neither, and exercises/sets are filled in as the workout progresses. Planned exercises are a snapshot only — there's no link back to the template, so editing a session never affects it.",
      "item": [
        {
          "name": "List workout templates",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/api/v1/workout-templates", "host": ["{{baseUrl}}"], "path": ["api", "v1", "workout-templates"] }, "description": "Returns all workout templates with their exercise ids." },
          "response": []
        },
        {
          "name": "Create workout template",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "if (body && body.id) { pm.collectionVariables.set('templateId', body.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Push day\",\n  \"exerciseIds\": [1, 4]\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/workout-templates", "host": ["{{baseUrl}}"], "path": ["api", "v1", "workout-templates"] },
            "description": "Creates a template. `name` required, at least one exerciseId required, each must reference an existing exercise (else 404). Returns 201 and stores the id in `templateId`."
          },
          "response": []
        },
        {
          "name": "Create workout template - validation error (example)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"\",\n  \"exerciseIds\": []\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/workout-templates", "host": ["{{baseUrl}}"], "path": ["api", "v1", "workout-templates"] },
            "description": "Demonstrates the 400 validation response (blank name, empty exerciseIds)."
          },
          "response": []
        },
        {
          "name": "Get workout template",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/api/v1/workout-templates/{{templateId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "workout-templates", "{{templateId}}"] }, "description": "Returns a single template by id, or 404 if not found." },
          "response": []
        },
        {
          "name": "Update workout template",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Push day (v2)\",\n  \"exerciseIds\": [1, 4, 5]\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/workout-templates/{{templateId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "workout-templates", "{{templateId}}"] },
            "description": "Renames the template and replaces its exercise list. Returns 200, or 404 if the template/exercise is not found."
          },
          "response": []
        },
        {
          "name": "Delete workout template",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/workout-templates/{{templateId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "workout-templates", "{{templateId}}"] },
            "description": "Deletes the template by id. Returns 204, or 404 if not found."
          },
          "response": []
        },
        {
          "name": "List workout sessions",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/api/v1/workout-sessions", "host": ["{{baseUrl}}"], "path": ["api", "v1", "workout-sessions"] }, "description": "Returns all sessions (newest first) with their planned exercises and logged sets." },
          "response": []
        },
        {
          "name": "Create workout session",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "if (body && body.id) { pm.collectionVariables.set('sessionId', body.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"startedAt\": \"2026-06-18T05:00:00Z\",\n  \"finishedAt\": \"2026-06-18T06:00:00Z\",\n  \"exerciseIds\": [1],\n  \"sets\": [\n    { \"exerciseId\": 1, \"reps\": 10, \"weight\": 60 },\n    { \"exerciseId\": 1, \"reps\": 8, \"weight\": 65 }\n  ]\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/workout-sessions", "host": ["{{baseUrl}}"], "path": ["api", "v1", "workout-sessions"] },
            "description": "Logs a session. `startedAt` required (today or past), `finishedAt` optional. `exerciseIds` and `sets` are both required fields but may be empty arrays. Each entry needs an existing exerciseId (else 404); sets additionally need positive reps and weight >= 0. Returns 201 and stores the id in `sessionId`."
          },
          "response": []
        },
        {
          "name": "Start session from a template (example)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"startedAt\": \"2026-06-18T05:00:00Z\",\n  \"exerciseIds\": [1, 4],\n  \"sets\": []\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/workout-sessions", "host": ["{{baseUrl}}"], "path": ["api", "v1", "workout-sessions"] },
            "description": "Demonstrates starting a session from a template: the client resolves the template's `exerciseIds` (Workouts > Get workout template) and sends them here as the session's planned exercises, with no sets logged yet. The response's `exercises` array lists them; `sets` fills in as the workout progresses via Update workout session."
          },
          "response": []
        },
