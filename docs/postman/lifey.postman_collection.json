            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"dateTime\": \"2030-01-01T08:00:00\",\n  \"mealType\": null,\n  \"entries\": []\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/meals", "host": ["{{baseUrl}}"], "path": ["api", "v1", "meals"] },
            "description": "Demonstrates the 400 validation response (future dateTime, missing mealType, empty entries)."
          },
          "response": []
        },
        {
          "name": "Update meal",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"dateTime\": \"2026-06-18T08:30:00\",\n  \"mealType\": \"BREAKFAST\",\n  \"entries\": [\n    { \"foodId\": {{foodId}}, \"quantityInGrams\": 180 }\n  ]\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/meals/{{mealId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "meals", "{{mealId}}"] },
            "description": "Replaces the meal's fields and entry list. Returns 200, or 404 if meal/food not found."
          },
          "response": []
        },
        {
          "name": "Delete meal",
          "request": { "method": "DELETE", "header": [], "url": { "raw": "{{baseUrl}}/api/v1/meals/{{mealId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "meals", "{{mealId}}"] }, "description": "Deletes the meal (and its entries) by id. Returns 204, or 404 if not found." },
          "response": []
        }
      ]
    },
