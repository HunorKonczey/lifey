            "body": { "mode": "raw", "raw": "{\n  \"startedAt\": \"2026-06-18T05:00:00Z\",\n  \"finishedAt\": \"2026-06-18T06:30:00Z\",\n  \"exerciseIds\": [1],\n  \"sets\": [\n    { \"exerciseId\": 1, \"reps\": 12, \"weight\": 62.5 }\n  ]\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/workout-sessions/{{sessionId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "workout-sessions", "{{sessionId}}"] },
            "description": "Replaces the session's start/finish time, planned-exercise list, and set list (e.g. finish an in-progress workout, or log sets for a session that was started empty/from a template). Returns 200, or 404 if the session/exercise is not found."
          },
          "response": []
        },
        {
          "name": "Delete workout session",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/workout-sessions/{{sessionId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "workout-sessions", "{{sessionId}}"] },
            "description": "Deletes the session (and its sets) by id. Returns 204, or 404 if not found."
          },
          "response": []
        }
